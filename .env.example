NODE_ENV=development
PORT=3000

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=ownage
DB_PASS=ownage
DB_NAME=ownage
DB_SYNC=true

# JWT
JWT_ACCESS_SECRET=change-me-access
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=change-me-refresh
JWT_REFRESH_TTL=7d
JWT_TEMP_SECRET=change-me-temp
JWT_TEMP_TTL=15m

BCRYPT_ROUNDS=10

# Google OAuth — mobile SDK audiences
GOOGLE_IOS_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=
GOOGLE_WEB_CLIENT_ID=
# Google OAuth — browser redirect flow (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Apple OAuth
# Apple Sign-In — native mobile flow only needs the audience (iOS bundle ID).
APPLE_AUDIENCE=com.ownage.ownage
# Browser redirect flow (optional)
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_CALLBACK_URL=http://localhost:3000/auth/apple/callback
